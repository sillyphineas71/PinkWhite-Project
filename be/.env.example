# ==============================================================
# 🎯 PHASE 1: MODULE AUTH (CẦN CẤU HÌNH NGAY)
# ==============================================================

# 1. Môi trường cơ bản
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# 2. JWT Secrets (Có thể dùng tạm key mặc định này cho lúc dev)
JWT_ACCESS_SECRET="dev-access-secret-change-me-in-production-32chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-in-production-32chars"
JWT_REFRESH_TTL="7d"
BCRYPT_ROUNDS=10

# 3. Email Service (Dùng để gửi mã xác nhận & lấy lại mật khẩu)
# Hướng dẫn: Dùng tài khoản Gmail, tạo "App Password" (Mật khẩu ứng dụng) 16 ký tự để điền vào SMTP_PASSWORD.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="haiductran712@gmail.com"
SMTP_PASSWORD="mfij hxoe ympb kjav"
SMTP_FROM="noreply@yourdomain.com"

# 4. Google OAuth (Dùng cho UC009 Đăng nhập Google)
# Hướng dẫn: Vào Google Cloud Console -> Create Credentials -> OAuth Client ID
GOOGLE_CLIENT_ID="416199732141-v1a15cd66r7pnveh9b6lrk7kolcd11p3.apps.googleusercontent.com"


# ==============================================================
# 🚧 CÁC MODULE SAU MỚI CẦN (HIỆN TẠI HÃY BỎ QUA)
# ==============================================================

# Database (Sẽ cấu hình khi chuyển từ Mock Data sang Prisma)
DATABASE_URL="postgresql://match_user:match_password@localhost:5432/matchmaking?schema=public"

# Redis (Sẽ cần cho Phase Realtime/Chat/Swipe)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Firebase (Sẽ cần cho thông báo Push Notification sau này)
FIREBASE_PROJECT_ID=""
